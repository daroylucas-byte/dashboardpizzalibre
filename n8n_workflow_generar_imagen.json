    {
      "parameters": {
        "jsCode": "const promo = $input.first().json;\nif (!promo || !promo.id) throw new Error('Promo no encontrada');\n\nconst { id, nombre_promo, productos, razon, beneficio, clima_dia } = promo;\n\nconst imagePrompt = `Professional food photography for a pizzeria promotion poster in Argentina.\nPromotion: \"${nombre_promo}\".\nProducts: ${productos}.\nOffer: ${beneficio}.\nContext: ${razon}.\nWeather today: ${clima_dia || ''}.\nStyle: warm restaurant lighting, rustic wooden table, appetizing close-up of pizza with melted mozzarella and colorful toppings, cold beverage bottle with condensation droplets beside it, bokeh background.\nMood: inviting, commercial, vibrant colors. Square format. No text overlays. No people.`;\n\nreturn [{ json: { promo_id: id, imagePrompt, nombre_promo } }];"
      },
      "id": "4",
      "name": "Preparar prompt de imagen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-image:generateContent?key=TU_GEMINI_API_KEY_ACA",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        { \"text\": {{ JSON.stringify($json.imagePrompt) }} }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseModalities\": [\"IMAGE\", \"TEXT\"],\n    \"responseMimeType\": \"text/plain\"\n  }\n}",
        "options": {}
      },
      "id": "5",
      "name": "Gemini Imagen 3 - Generar",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1120,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst promo_id = $('Preparar prompt de imagen').first().json.promo_id;\n\nconst parts = response.candidates?.[0]?.content?.parts || [];\nconst imagePart = parts.find(p => p.inlineData?.mimeType?.startsWith('image/'));\n\nif (!imagePart) throw new Error('Gemini no devolvió imagen: ' + JSON.stringify(response));\n\nconst base64 = imagePart.inlineData.data;\nconst mimeType = imagePart.inlineData.mimeType || 'image/png';\nconst filename = `promo_${promo_id}_${Date.now()}.png`;\n\n// Convertir base64 a binario para que n8n lo trate como archivo\nconst binaryData = Buffer.from(base64, 'base64');\n\nreturn [{\n  json: { promo_id, filename },\n  binary: {\n    data: {\n      data: binaryData.toString('base64'),\n      mimeType,\n      fileName: filename,\n      fileSize: binaryData.length\n    }\n  }\n}];"
      },
